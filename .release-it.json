{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "git": {
    "tagName": "v${version}",
    "commitMessage": "chore(release): v${version}",
    "tagAnnotation": "v${version}",
    "push": false,
    "requireBranch": "main",
    "requireCleanWorkingDir": true
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false
  },
  "hooks": {
    "before:bump": "./contrib/changelog-hook ${version}"
  }
}
