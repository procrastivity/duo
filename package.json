{
  "name": "@procrastivity/duo",
  "version": "0.1.4",
  "description": "Solo MCP companion for agent tier-based selection and override-aware orchestration.",
  "type": "module",
  "bin": {
    "duo": "./dist/duo.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/duo.mjs",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:bundle",
    "build:bundle": "node scripts/build.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test",
    "build:bin:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile=dist/bin/duo-darwin-arm64",
    "build:bin:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile=dist/bin/duo-darwin-x64",
    "release": "release-it"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "citty": "^0.2.2",
    "execa": "^9.6.0",
    "pino": "^9.6.0",
    "yaml": "^2.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "esbuild": "^0.28.0",
    "release-it": "^17.10.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/procrastivity/duo.git"
  }
}
