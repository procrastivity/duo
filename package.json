{
  "name": "@procrastivity/duo",
  "version": "0.1.8",
  "description": "Solo MCP companion for agent preset selection, provider toggles, and per-launch extra_args.",
  "type": "module",
  "bin": {
    "duo": "./dist/duo.mjs"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist/duo.mjs",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:bundle",
    "build:bundle": "node scripts/build.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test",
    "build:bin:darwin-arm64": "node scripts/build-bin.mjs bun-darwin-arm64 dist/bin/duo-darwin-arm64",
    "build:bin:linux-x64": "node scripts/build-bin.mjs bun-linux-x64 dist/bin/duo-linux-x64",
    "build:bin:linux-arm64": "node scripts/build-bin.mjs bun-linux-arm64 dist/bin/duo-linux-arm64",
    "build:bin:all": "npm run build:bin:darwin-arm64 && npm run build:bin:linux-x64 && npm run build:bin:linux-arm64",
    "release": "release-it"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "citty": "^0.2.2",
    "execa": "^9.6.0",
    "pino": "^10.3.1",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.0",
    "release-it": "^20.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/procrastivity/duo.git"
  }
}
